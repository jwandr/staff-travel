{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Permitted Airlines",
  "description": "Staff travel permitted airlines with class entitlements",
  "type": "object",
  "required": ["airlines"],
  "properties": {
    "airlines": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["iata_code", "airline_name", "permitted_classes"],
        "properties": {
          "iata_code": {
            "type": "string",
            "description": "2-character IATA airline code (e.g. QF, EK, SQ)",
            "pattern": "^[A-Z0-9]{2}$"
          },
          "airline_name": {
            "type": "string",
            "description": "Full airline name"
          },
          "country": {
            "type": "string",
            "description": "Country of operation"
          },
          "alliance": {
            "type": "string",
            "enum": ["oneworld", "Star Alliance", "SkyTeam", "none", null],
            "description": "Airline alliance membership"
          },
          "permitted_classes": {
            "type": "array",
            "description": "Travel classes staff are permitted to use on this airline",
            "items": {
              "type": "string",
              "enum": ["F", "J", "W", "Y"],
              "description": "F=First, J=Business, W=Premium Economy, Y=Economy"
            },
            "minItems": 1
          },
          "notes": {
            "type": "string",
            "description": "Any special conditions, restrictions or notes for this carrier"
          },
          "staff_fare_type": {
            "type": "string",
            "enum": ["ID90", "ID75", "ID50", "ZED", "myIDTravel", "Other"],
            "description": "Type of staff fare agreement"
          },
          "listing_required": {
            "type": "boolean",
            "description": "Whether listing / advance seat request is required"
          },
          "booking_platform": {
            "type": "string",
            "description": "Platform used to book (e.g. myIDTravel, Sabre, direct)"
          }
        }
      }
    },
    "metadata": {
      "type": "object",
      "description": "Optional metadata about the file itself",
      "properties": {
        "last_updated": { "type": "string", "description": "ISO 8601 date string" },
        "maintained_by": { "type": "string" },
        "notes": { "type": "string" }
      }
    }
  }
}
